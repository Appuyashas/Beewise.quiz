INSERT INTO beexam_questions (id, paper_id, question, opt0, opt1, opt2, opt3, category) VALUES
  (106, 3, 'A group of researchers produced some fish-like animals and observed cartilage endoskeleton', 'Petromyzon sp', 'Branchiostoma sp', 'Scoliodon sp', 'Exocoetus sp', 'Biology'),
  (107, 3, 'Spermatids transform into spermatozoa by which process?', 'Spermiogenesis', 'Mitosis', 'Meiosis', 'Binary fission', 'Biology'),
  (108, 3, 'Which cells produce haploid spermatids through second meiotic division?', 'Secondary spermatocytes', 'Primary spermatocytes', 'Spermatogonia', 'Sertoli cells', 'Biology'),
  (109, 3, 'What is the probability of getting O blood group from heterozygous A and B parents?', '25%', '50%', '75%', '0%', 'Genetics'),
  (110, 3, 'What increases blood pressure during Renin-Angiotensin mechanism?', 'Angiotensin II', 'Insulin', 'Glucagon', 'Thyroxine', 'Biology'),
  (111, 3, 'What occurs after Angiotensin II release in RAAS?', 'Aldosterone secretion', 'Decrease in BP', 'Loss of sodium', 'Decrease in filtration', 'Biology'),
  (112, 3, 'What is the tidal volume capacity in humans?', '500 mL', '2500 mL', '1100 mL', '3000 mL', 'Biology'),
  (113, 3, 'What is the inspiratory reserve volume in humans?', '2500-3000 mL', '500 mL', '1000-1100 mL', '1100-1200 mL', 'Biology'),
  (114, 3, 'Residual volume in humans is approximately?', '1100-1200 mL', '500 mL', '2500-3000 mL', '1000-1100 mL', 'Biology'),
  (115, 3, 'Which organism has a circular sucking mouth and gill slits?', 'Petromyzon sp', 'Branchiostoma sp', 'Scoliodon sp', 'Exocoetus sp', 'Zoology');

