INSERT INTO room_quiz_sessions (id, user_id, room_id, room_title, questions, idx, score, total, start_time, end_time, created) VALUES
  (4, 8, 6, 'test two', '[{"q": "\u0917\u0924\u093f\u092e\u093e\u0928 \u090f\u0915\u094d\u0938\u092a\u094d\u0930\u0947\u0938 \u0915\u093f\u0928 \u0926\u094b \u0936\u0939\u0930\u094b\u0902 \u0915\u0947 \u092c\u0940\u091a \u091a\u0932\u0924\u0940 \u0939\u0948?", "options": ["\u0926\u093f\u0932\u094d\u0932\u0940 \u0914\u0930 \u0906\u0917\u0930\u093e", "\u092e\u0941\u0902\u092c\u0908 \u0914\u0930 \u092a\u0941\u0923\u0947", "\u0926\u093f\u0932\u094d\u0932\u0940 \u0914\u0930 \u0932\u0916\u0928\u090a", "\u0926\u093f\u0932\u094d\u0932\u0940 \u0914\u0930 \u091c\u092f\u092a\u0941\u0930"], "a": 0, "cat": "Quiz Room"}, {"q": "\u0930\u0947\u0932\u0935\u0947 \u091f\u093f\u0915\u091f \u092a\u0930 WL \u0915\u093e \u0915\u094d\u092f\u093e \u0905\u0930\u094d\u0925 \u0939\u0948?", "options": ["\u092a\u094d\u0930\u0924\u0940\u0915\u094d\u0937\u093e \u0938\u0942\u091a\u0940 (Waiting List)", "\u0935\u0947\u0932 \u0932\u093f\u0938\u094d\u091f", "\u0935\u0948\u0932\u093f\u0921 \u0932\u093f\u0938\u094d\u091f", "\u0935\u0930\u094d\u0915\u093f\u0902\u0917 \u0932\u093e\u0907\u0928"], "a": 0, "cat": "Quiz Room"}, {"q": "\u0930\u0947\u0932\u0935\u0947 \u0938\u094d\u091f\u0947\u0936\u0928 \u092a\u0930 \u0932\u093e\u0932 \u092c\u0924\u094d\u0924\u0940 \u0915\u093e \u0915\u094d\u092f\u093e \u092e\u0924\u0932\u092c \u0939\u094b\u0924\u093e \u0939\u0948?", "options": ["\u0938\u093e\u0935\u0927\u093e\u0928\u0940 \u0915\u093e \u0938\u0902\u0915\u0947\u0924", "\u091f\u094d\u0930\u0948\u0915 \u0916\u0930\u093e\u092c \u0939\u0948", "\u091f\u094d\u0930\u0947\u0928 \u0915\u094b \u0930\u094b\u0915\u0928\u0947 \u0915\u093e \u0938\u0902\u0915\u0947\u0924", "\u091f\u094d\u0930\u0947\u0928 \u0915\u094b \u0906\u0917\u0947 \u091c\u093e\u0928\u0947 \u0915\u093e \u0938\u0902\u0915\u0947\u0924"], "a": 2, "cat": "Quiz Room"}, {"q": "\u092d\u093e\u0930\u0924 \u092e\u0947\u0902 \u0915\u093f\u0924\u0928\u0947 \u0930\u0947\u0932\u0935\u0947 \u092e\u0902\u0921\u0932 \u0939\u0948\u0902?", "options": ["75", "68", "70", "60"], "a": 2, "cat": "Quiz Room"}, {"q": "\u092d\u093e\u0930\u0924 \u092e\u0947\u0902 \u0930\u0947\u0932\u0935\u0947 \u0926\u093f\u0935\u0938 \u0915\u092c \u092e\u0928\u093e\u092f\u093e \u091c\u093e\u0924\u093e \u0939\u0948?", "options": ["1 \u092e\u093e\u0930\u094d\u091a", "16 \u0905\u092a\u094d\u0930\u0948\u0932", "26 \u091c\u0928\u0935\u0930\u0940", "15 \u0905\u0917\u0938\u094d\u0924"], "a": 1, "cat": "Quiz Room"}, {"q": "\u0930\u0947\u0932\u0935\u0947 \u092e\u0947\u0902 FOB \u0915\u093e \u092a\u0942\u0930\u093e \u0928\u093e\u092e \u0915\u094d\u092f\u093e \u0939\u0948?", "options": ["Free On Board", "Floor Over Bridge", "Foot Over Bridge", "Front Over Board"], "a": 2, "cat": "Quiz Room"}, {"q": "\u0939\u0930\u0947 \u0938\u093f\u0917\u094d\u0928\u0932 \u0915\u093e \u0915\u094d\u092f\u093e \u0905\u0930\u094d\u0925 \u0939\u0948?", "options": ["\u0927\u0940\u092e\u0947 \u091a\u0932\u094b", "\u0938\u093e\u0935\u0927\u093e\u0928", "\u0930\u0941\u0915\u094b", "\u0906\u0917\u0947 \u092c\u0922\u093c\u094b (Go)"], "a": 3, "cat": "Quiz Room"}, {"q": "\u091f\u094d\u0930\u0947\u0928 \u092e\u0947\u0902 AC 1 \u091f\u093f\u092f\u0930 \u092e\u0947\u0902 \u0915\u093f\u0924\u0928\u0947 \u092f\u093e\u0924\u094d\u0930\u0940 \u0939\u094b\u0924\u0947 \u0939\u0948\u0902?", "options": ["24", "12", "18", "36"], "a": 2, "cat": "Quiz Room"}, {"q": "\u0930\u0947\u0932\u0935\u0947 \u0915\u0930\u094d\u092e\u091a\u093e\u0930\u0940 \u0915\u093e \u092a\u094d\u0930\u0936\u093f\u0915\u094d\u0937\u0923 \u0915\u0947\u0902\u0926\u094d\u0930 NRA \u0915\u0939\u093e\u0901 \u0939\u0948?", "options": ["\u091a\u0947\u0928\u094d\u0928\u0908", "\u0907\u0932\u093e\u0939\u093e\u092c\u093e\u0926", "\u092e\u0941\u0902\u092c\u0908", "\u0926\u093f\u0932\u094d\u0932\u0940"], "a": 1, "cat": "Quiz Room"}, {"q": "\u092d\u093e\u0930\u0924\u0940\u092f \u0930\u0947\u0932\u0935\u0947 \u0915\u093e \u092a\u094d\u0930\u0924\u0940\u0915 \u091a\u093f\u0939\u094d\u0928 \u0915\u094d\u092f\u093e \u0939\u0948?", "options": ["\u0907\u09