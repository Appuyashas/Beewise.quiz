INSERT INTO cb_sessions (id, user_id, questions, idx, score, log, total, end_time, created) VALUES
  (35, 17, '[{"q": "A group of researchers produced some fish-like animals and observed cartilage endoskeleton", "options": ["Petromyzon sp", "Scoliodon sp", "Exocoetus sp", "Branchiostoma sp"], "a": 0, "cat": "Biology"}, {"q": "Spermatids transform into spermatozoa by which process?", "options": ["Mitosis", "Spermiogenesis", "Binary fission", "Meiosis"], "a": 1, "cat": "Biology"}, {"q": "Which cells produce haploid spermatids through second meiotic division?", "options": ["Sertoli cells", "Spermatogonia", "Secondary spermatocytes", "Primary spermatocytes"], "a": 2, "cat": "Biology"}, {"q": "What is the probability of getting O blood group from heterozygous A and B parents?", "options": ["50%", "75%", "25%", "0%"], "a": 2, "cat": "Genetics"}, {"q": "What increases blood pressure during Renin-Angiotensin mechanism?", "options": ["Glucagon", "Insulin", "Thyroxine", "Angiotensin II"], "a": 3, "cat": "Biology"}, {"q": "What occurs after Angiotensin II release in RAAS?", "options": ["Decrease in BP", "Decrease in filtration", "Aldosterone secretion", "Loss of sodium"], "a": 2, "cat": "Biology"}, {"q": "What is the tidal volume capacity in humans?", "options": ["500 mL", "2500 mL", "3000 mL", "1100 mL"], "a": 0, "cat": "Biology"}, {"q": "What is the inspiratory reserve volume in humans?", "options": ["500 mL", "1000-1100 mL", "1100-1200 mL", "2500-3000 mL"], "a": 3, "cat": "Biology"}, {"q": "Residual volume in humans is approximately?", "options": ["1000-1100 mL", "500 mL", "1100-1200 mL", "2500-3000 mL"], "a": 2, "cat": "Biology"}, {"q": "Which organism has a circular sucking mouth and gill slits?", "options": ["Scoliodon sp", "Petromyzon sp", "Exocoetus sp", "Branchiostoma sp"], "a": 1, "cat": "Zoology"}]', 0, 0, '[]', 10, 1779637564.7372382, '2026-05-24 15:36:04'),
  (39, 1, '[{"q": "\u65e5\u672c\u306e\u9996\u90fd\u306f\u3069\u3053\u3067\u3059\u304b\uff1f", "options": ["\u540d\u53e4\u5c4b", "\u5927\u962a", "\u6771\u4eac", "\u4eac\u90fd"], "a": 2, "cat": "\u4e00\u822c\u77e5\u8b58"}, {"q": "\u5bcc\u58eb\u5c71\u306e\u9ad8\u3055\u306f\u3069\u308c\u304f\u3089\u3044\u3067\u3059\u304b\uff1f", "options": ["3500\u30e1\u30fc\u30c8\u30eb", "3200\u30e1\u30fc\u30c8\u30eb", "3776\u30e1\u30fc\u30c8\u30eb", "4000\u30e1\u30fc\u30c8\u30eb"], "a": 2, "cat": "\u5730\u7406"}, {"q": "\u65e5\u672c\u306e\u56fd\u65d7\u306e\u8272\u306f\u4f55\u3067\u3059\u304b\uff1f", "options": ["\u767d\u3068\u8d64", "\u9752\u3068\u767d", "\u9ed2\u3068\u8d64", "\u8d64\u3068\u9752"], "a": 0, "cat": "\u4e00\u822c\u77e5\u8b58"}, {"q": "\u300c\u3042\u308a\u304c\u3068\u3046\u300d\u306f\u82f1\u8a9e\u3067\u4f55\u3067\u3059\u304b\uff1f", "options": ["Goodbye", "Hello", "Thank you", "Sorry"], "a": 2, "cat": "\u65e5\u672c\u8a9e"}, {"q": "\u65e5\u672c\u306e\u901a\u8ca8\u306f\u4f55\u3067\u3059\u304b\uff1f", "options": ["\u30c9\u30eb", "\u30a6\u30a9\u30f3", "\u5186\uff08\u3048\u3093\uff09", "\u30d0\u30fc\u30c4"], "a": 2, "cat": "\u4e00\u822c\u77e5\u8b58"}, {"q": "\u5bff\u53f8\u306b\u4f7f\u308f\u308c\u308b\u9b5a\u3068\u3057\u3066\u6700\u3082\u6709\u540d\u306a\u306e\u306f\uff1f", "options": ["\u30bf\u30a4", "\u30b5\u30fc\u30e2\u30f3", "\u30a2\u30b8", "\u30de\u30b0\u30ed"], "a": 3, "cat": "\u98df\u6587\u5316"}, {"q": "\u65e5\u672c\u306e\u30a2\u30cb\u30e1\u3067\u6709\u540d\u306a\u30b9\u30bf\u30b8\u30aa\u306f\u3069\u3053\u3067\u3059\u304b\uff1f", "options": ["\u30d4\u30af\u30b5\u30fc", "\u30c7\u30a3\u30ba\u30cb\u30fc", "\u30c9\u30ea\u30fc\u30e0\u30ef\u30fc\u30af\u30b9", "\u30b9\u30bf\u30b8\u30aa\u30b8\u30d6\u30ea"], "a": 3, "cat": "\u6587\u5316"}, {"q": "\u685c\u306e\u82b1\u306f\u4f55\u6708\u306b\u54b2\u304d\u307e\u3059\u304b\uff1f", "options": ["1\u6708\u301c2\u6708", "11\u6708\u301c12\u6708", "3\u6708\u301c4\u6708", "6\u6708\u301c7\u6708"], "a": 2, "cat": "\u81ea\u7136"}, {"q": "\u65e5\u672c\u3067\u6700\u3082\u4eba\u53e3\u304c\u591a\u3044\u90fd\u5e02\u306f\u3069\u3053\u3067\u3059\u304b\uff1f", "options": ["\u5927\u962a", "\u6a2a\u6d5c", "\u540d\u53e4\u5c4b", "\u6771\u4eac"], "a": 3, "cat": "\u5730\u7406"}, {"q": "\u300c\u3053\u3093\u306b\u3061\u306f\u300d\u306e\u610f\u5473\u306f\u4f55\u3067\u3059\u304b\uff1f", "options": ["\u3053\u3093\u306b\u3061\u306f\uff08Hello\uff09", "\u3042\u308a\u304c\u3068\u3046\uff08Thank you\uff09", "\u3059\u307f\u307e\u305b\u3093\uff08Excuse me\uff09", "\u3055\u3088\u3046\u306a\u3089\uff08Goodbye\uff09"], "a": 0, "cat": "\u65e5\u672c\u8a9e"}]', 3, 0, '[{"q": "\u65e5\u672c\u306e\u9996\u90fd\u306f\u3069\u3053\u3067\u3059\u304b\uff1f", "options": ["\u540d\u53e4\u5c4b", "\u5927\u962a", "\u6771\u4eac", "\u4eac\u90fd"], "chosen": 1, "correct": 2, "cat": "\u4e00\u822c\u77e5\u8b58"}, {"q": "\u5bcc\u58eb\u5c71\u306e\u9ad8\u3055\u306f\u3069\u308c\u304f\u3089\u3044\u3067\u3059\u304b\uff1f", "options": ["3500\u30e1\u30fc\u30c8\u30eb", "3200\u30e1\u30fc\u30c8\u30eb", "3776\u30e1\u30fc\u30c8\u30eb", "4000\u30e1\u30fc\u30c8\u30eb"], "chosen": 0, "correct": 2, "cat": "\u5730\u7406"}, {"q": "\u65e5\u672c\u306e\u56fd\u65d7\u306e\u8272\u306f\u4f55\u3067\u3059\u304b\uff1f", "options": ["\u767d\u3068\u8d64", "\u9752\u3068\u767d", "\u9ed2\u3068\u8d64", "\u8d64\u3068\u9752"], "chosen": 1, "correct": 0, "cat": "\u4e00\u822c\u77e5\u8b58"}]', 10, 1779783660.627744, '2026-05-26 08:11:00');

-- rb_temp (2 rows)
INSERT INTO rb_temp (user_id, questions_json, log_json, score, tabs, created) VALUES
  (1, '[{"q": "Which gas has the smell of rotten eggs?", "options": ["Ammonia", "Chlorine", "Hydrogen sulphide", "Sulphur dioxide"], "a": 2, "cat": "Chemistry"}, {"q": "What is 5% of 1000?", "options": ["45", "50", "55", "100"], "a": 1, "cat": "Mathematics"}, {"q": "Which country hosted the first modern Olympic Games?", "options": ["UK", "France", "USA", "Greece"], "a": 3, "cat": "History"}, {"q": "What is the world''s most traded commodity?", "options": ["Coffee", "Wheat", "Crude Oil", "Gold"], "a": 2, "cat": "General Knowledge"}, {"q": "What is the Milky Way?", "options": ["The galaxy containing our solar system", "A type of star cluster", "A type of nebula", "A nearby star system"], "a": 0, "cat": "Science"}, {"q": "The number of electrons in the outermost shell of noble gases is:", "options": ["2", "0", "1", "8"], "a": 3, "cat": "Chemistry"}, {"q": "Which particle has a positive charge?", "options": ["Electron", "Neutron", "Proton", "Photon"], "a": 2, "cat": "Physics"}, {"q": "Ashoka was a ruler of which dynasty?", "options": ["Maurya", "Gupta", "Kushan", "Nanda"], "a": 0, "cat": "Indian History"}, {"q": "The Hardy-Weinberg principle applies to:", "options": ["Population genetics", "Photosynthesis", "Protein synthesis", "Cell division"], "a": 0, "cat": "Biology"}, {"q": "Which HTTP method is used to update a resource?", "options": ["POST", "PUT", "DELETE", "GET"], "a": 1, "cat": "Computer Science"}, {"q": "What is the mean of 10, 20, 30, 40, 50?", "options": ["30", "25", "35", "40"], "a": 0, "cat": "Mathematics"}, {"q": "SEBI regulates:", "options": ["Insurance sector", "Banking sector", "Commodity markets", "Stock markets"], "a": 3, "cat": "Economics"}, {"q": "''The cat sat on the mat.'' This is a:", "options": ["Compound-complex", "Complex sentence", "Simple sentence", "Compound sentence"], "a": 2, "cat": "English Grammar"}, {"q": "Which data structure uses FIFO ordering?", "options": ["Queue", "Stack", "Graph", "Heap"], "a": 0, "cat": "Computer Science"}, {"q": "Which fuel produces the least carbon emissions?", "options": ["Natural gas", "Coal", "Diesel", "Petrol"], "a": 0, "cat": "Environmental Science"}, {"q": "Which plateau separates north and south India?", "options": ["Chota Nagpur Plateau", "Bundelkhand Plateau", "Malwa Plateau", "Deccan Plateau"], "a": 3, "cat": "Indian Geography"}, {"q": "India''s UPI payment system was developed by:", "options": ["SBI", "RBI", "NPCI", "NITI Aayog"], "a": 2, "cat": "Current Affairs"}, {"q": "A train travels 60 km in 1 hour. How far does it travel in 45 minutes?", "options": ["50 km", "40 km", "45 km", "60 km"], "a": 2, "cat": "Logical Reasoning"}, {"q": "The process by which cells divide is called:", "options": ["Mitosis", "Meiosis", "Both", "Cytokinesis"], "a": 0, "cat": "Biology"}, {"q": "What is Newton''s First Law called?", "options": ["Law of Gravity", "Law of Action-Reaction", "Law of Acceleration", "Law of Inertia"], "a": 3, "cat": "Science"}, {"q": "What was the Silk Road?", "options": ["A road made of silk in China", "A maritime trade route", "Ancient trade routes connecting Asia and Europe", "A modern highway"], "a": 2, "cat": "History"}, {"q": "The Amazon rainforest is primarily in which country?", "options": ["Venezuela", "Colombia", "Peru", "Brazil"], "a": 3, "cat": "Geography"}, {"q": "The Great Dividing Range is in which country?", "options": ["Canada", "Australia", "New Zealand", "USA"], "a": 1, "cat": "Geography"}, {"q": "What is the lightest element?", "options": ["Helium", "Lithium", "Hydrogen", "Beryllium"], "a": 2, "cat": "General Knowledge"}, {"q": "Which amendment added Fundamental Duties to the Constitution?", "options": ["44th", "52nd", "74th", "42nd"], "a": 3, "cat": "Civics"}]', '[]', 0, 0, '2026-06-09 11:21:46'),
