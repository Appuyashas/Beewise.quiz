uiz Room"}, {"q": "\u092d\u093e\u0930\u0924 \u0915\u093e \u092a\u0939\u0932\u093e \u0930\u0947\u0932\u0935\u0947 \u0938\u094d\u091f\u0947\u0936\u0928 \u0915\u094c\u0928 \u0938\u093e \u0925\u093e?", "options": ["\u092c\u094b\u0930\u0940 \u092c\u0902\u0926\u0930 (\u092e\u0941\u0902\u092c\u0908)", "\u0926\u093f\u0932\u094d\u0932\u0940 \u091c\u0902\u0915\u094d\u0936\u0928", "\u091a\u0947\u0928\u094d\u0928\u0908 \u0938\u0947\u0902\u091f\u094d\u0930\u0932", "\u0939\u093e\u0935\u0921\u093c\u093e"], "a": 0, "cat": "Quiz Room"}, {"q": "\u0915\u094b\u092f\u0932\u0947 \u0938\u0947 \u091a\u0932\u0928\u0947 \u0935\u093e\u0932\u093e \u0907\u0902\u091c\u0928 \u0915\u092c \u0938\u0947 \u092c\u0902\u0926 \u0939\u0941\u0906?", "options": ["2000 \u092e\u0947\u0902", "1990 \u092e\u0947\u0902", "1980 \u0915\u0947 \u0926\u0936\u0915 \u092e\u0947\u0902", "1970 \u092e\u0947\u0902"], "a": 2, "cat": "Quiz Room"}, {"q": "\u092d\u093e\u0930\u0924 \u092e\u0947\u0902 \u0930\u0947\u0932\u0935\u0947 \u0935\u093f\u0936\u094d\u0935 \u092e\u0947\u0902 \u0915\u093f\u0938 \u0938\u094d\u0925\u093e\u0928 \u092a\u0930 \u0939\u0948 (\u0928\u0947\u091f\u0935\u0930\u094d\u0915 \u0915\u0947 \u0906\u0927\u093e\u0930 \u092a\u0930)?", "options": ["\u091a\u094c\u0925\u0947", "\u0926\u0942\u0938\u0930\u0947", "\u092a\u093e\u0901\u091a\u0935\u0947", "\u0924\u0940\u0938\u0930\u0947"], "a": 0, "cat": "Quiz Room"}, {"q": "\u092d\u093e\u0930\u0924 \u092e\u0947\u0902 \u0938\u092c\u0938\u0947 \u091b\u094b\u091f\u093e \u0930\u0947\u0932\u0935\u0947 \u091c\u093c\u094b\u0928 \u0915\u094c\u0928 \u0938\u093e \u0939\u0948?", "options": ["\u092a\u0942\u0930\u094d\u0935 \u0924\u091f\u0940\u092f \u0930\u0947\u0932\u0935\u0947", "\u092e\u0927\u094d\u092f \u0930\u0947\u0932\u0935\u0947", "\u0909\u0924\u094d\u0924\u0930 \u0938\u0940\u092e\u093e\u0902\u0924 \u0930\u0947\u0932\u0935\u0947", "\u0926\u0915\u094d\u0937\u093f\u0923 \u092a\u0942\u0930\u094d\u0935 \u0930\u0947\u0932\u0935\u0947"], "a": 2, "cat": "Quiz Room"}, {"q": "NTES \u0915\u093e \u092a\u0942\u0930\u093e \u0928\u093e\u092e \u0915\u094d\u092f\u093e \u0939\u0948?", "options": ["National Train Enquiry System", "National Transit Enquiry System", "National Travel Enquiry Service", "National Ticket Enquiry System"], "a": 0, "cat": "Quiz Room"}, {"q": "\u092d\u093e\u0930\u0924 \u0915\u0940 \u092a\u0939\u0932\u0940 \u092c\u0941\u0932\u0947\u091f \u091f\u094d\u0930\u0947\u0928 \u092a\u0930\u093f\u092f\u094b\u091c\u0928\u093e \u092e\u0947\u0902 \u0915\u093f\u0938 \u0926\u0947\u0936 \u0915\u0940 \u092e\u0926\u0926 \u0939\u0948?", "options": ["\u091c\u093e\u092a\u093e\u0928", "\u091c\u0930\u094d\u092e\u0928\u0940", "\u092b\u094d\u0930\u093e\u0902\u0938", "\u091a\u0940\u0928"], "a": 0, "cat": "Quiz Room"}, {"q": "\u092d\u093e\u0930\u0924 \u092e\u0947\u0902 \u092c\u0941\u0932\u0947\u091f \u091f\u094d\u0930\u0947\u0928 \u092a\u0930\u093f\u092f\u094b\u091c\u0928\u093e \u0915\u093f\u0928 \u0926\u094b \u0936\u0939\u0930\u094b\u0902 \u0915\u0947 \u092c\u0940\u091a \u0939\u0948?", "options": ["\u0926\u093f\u0932\u094d\u0932\u0940 \u0914\u0930 \u092e\u0941\u0902\u092c\u0908", "\u092e\u0941\u0902\u092c\u0908 \u0914\u0930 \u092a\u0941\u0923\u0947", "\u0926\u093f\u0932\u094d\u0932\u0940 \u0914\u0930 \u0915\u094b\u0932\u0915\u093e\u0924\u093e", "\u092e\u0941\u0902\u092c\u0908 \u0914\u0930 \u0905\u0939\u092e\u0926\u093e\u092c\u093e\u0926"], "a": 3, "cat": "Quiz Room"}, {"q": "\u092d\u093e\u0930\u0924 \u0915\u093e \u0938\u092c\u0938\u0947 \u090a\u0901\u091a\u093e \u0930\u0947\u0932\u0935\u0947 \u092a\u0941\u0932 \u0915\u0939\u093e\u0901 \u0939\u0948?", "options": ["\u091c\u092e\u094d\u092e\u0942 \u092e\u0947\u0902 (\u091a\u093f\u0928\u093e\u092c \u092c\u094d\u0930\u093f\u091c)", "\u0909\u0924\u094d\u0924\u0930\u093e\u0916\u0902\u0921 \u092e\u0947\u0902", "\u0939\u093f\u092e\u093e\u091a\u0932 \u092a\u094d\u0930\u0926\u0947\u0936 \u092e\u0947\u0902", "\u0938\u093f\u0915\u094d\u0915\u093f\u092e \u092e\u0947\u0902"], "a": 0, "cat": "Quiz Room"}]', 0, 0, 95, 1778473752.0020657, 1778485152.0020657, '2026-05-11 04:29:12');

