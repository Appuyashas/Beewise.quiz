-- =============================================
-- Beewise Quiz  ·  Supabase Migration
-- SQLite → PostgreSQL
-- Generated automatically from beewise.db
-- Run this in: Supabase Dashboard → SQL Editor
-- =============================================

-- ── TABLES ──────────────────────────────────

CREATE TABLE IF NOT EXISTS users (
  id SERIAL PRIMARY KEY,
  username TEXT NOT NULL,
  password TEXT NOT NULL,
  is_admin INTEGER DEFAULT 0,
  created TIMESTAMPTZ DEFAULT NOW(),
  avatar TEXT DEFAULT '🐝',
  streak INTEGER DEFAULT 0,
  last_play TIMESTAMPTZ DEFAULT NULL,
  role TEXT DEFAULT 'student'
);

CREATE TABLE IF NOT EXISTS questions_db (
  id SERIAL PRIMARY KEY,
  question TEXT NOT NULL,
  opt0 TEXT NOT NULL,
  opt1 TEXT NOT NULL,
  opt2 TEXT NOT NULL,
  opt3 TEXT NOT NULL,
  answer INTEGER NOT NULL DEFAULT 0,
  category TEXT NOT NULL DEFAULT 'General',
  active INTEGER DEFAULT 1,
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS results (
  id SERIAL PRIMARY KEY,
  user_id INTEGER NOT NULL REFERENCES users(id),
  mode TEXT NOT NULL,
  score INTEGER NOT NULL,
  total INTEGER NOT NULL,
  pct INTEGER NOT NULL,
  grade TEXT NOT NULL,
  time_taken INTEGER DEFAULT 0,
  played_at TIMESTAMPTZ DEFAULT NOW(),
  tab_switches INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS answer_log (
  id SERIAL PRIMARY KEY,
  result_id INTEGER NOT NULL REFERENCES results(id),
  question TEXT NOT NULL,
  category TEXT NOT NULL,
  correct INTEGER NOT NULL,
  time_spent INTEGER DEFAULT 0,
  user_ans INTEGER DEFAULT -1,
  correct_ans INTEGER DEFAULT 0
);

CREATE TABLE IF NOT EXISTS achievements (
  id SERIAL PRIMARY KEY,
  user_id INTEGER NOT NULL REFERENCES users(id),
  ach_id TEXT NOT NULL,
  earned_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS classes (
  id SERIAL PRIMARY KEY,
  name TEXT NOT NULL,
  code TEXT NOT NULL,
  created_by INTEGER NOT NULL,
  created TIMESTAMPTZ DEFAULT NOW(),
  admin_id INTEGER
);

CREATE TABLE IF NOT EXISTS class_members (
  id SERIAL PRIMARY KEY,
  class_id INTEGER NOT NULL,
  user_id INTEGER NOT NULL,
  joined TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS quiz_rooms (
  id SERIAL PRIMARY KEY,
  title TEXT NOT NULL,
  code TEXT NOT NULL,
  created_by INTEGER NOT NULL,
  questions TEXT NOT NULL,
  time_limit INTEGER DEFAULT 30,
  active INTEGER DEFAULT 1,
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS room_results (
  id SERIAL PRIMARY KEY,
  room_id INTEGER NOT NULL,
  user_id INTEGER NOT NULL,
  score INTEGER DEFAULT 0,
  total INTEGER DEFAULT 0,
  pct INTEGER DEFAULT 0,
  time_taken INTEGER DEFAULT 0,
  finished TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS room_quiz_sessions (
  id SERIAL PRIMARY KEY,
  user_id INTEGER NOT NULL,
  room_id INTEGER NOT NULL,
  room_title TEXT NOT NULL,
  questions TEXT NOT NULL,
  idx INTEGER DEFAULT 0,
  score INTEGER DEFAULT 0,
  total INTEGER DEFAULT 0,
  start_time DOUBLE PRECISION DEFAULT 0,
  end_time DOUBLE PRECISION DEFAULT 0,
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS exam_sessions (
  id SERIAL PRIMARY KEY,
  title TEXT NOT NULL,
  start_time TEXT NOT NULL,
  end_time TEXT NOT NULL,
  created_by INTEGER NOT NULL,
  active INTEGER DEFAULT 1,
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS scheduled_tests (
  id SERIAL PRIMARY KEY,
  teacher_id INTEGER NOT NULL,
  room_id INTEGER NOT NULL,
  class_id INTEGER,
  scheduled_at TEXT NOT NULL,
  note TEXT DEFAULT '',
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS beexam_exam_types (
  id SERIAL PRIMARY KEY,
  name TEXT NOT NULL,
  exam_group TEXT DEFAULT 'Other',
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS beexam_papers (
  id SERIAL PRIMARY KEY,
  exam_name TEXT NOT NULL,
  subject TEXT,
  year INTEGER NOT NULL,
  time_limit INTEGER NOT NULL DEFAULT 10800,
  cutoff INTEGER,
  exam_group TEXT DEFAULT 'Other',
  question_count INTEGER DEFAULT 0,
  created_by INTEGER,
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS beexam_questions (
  id SERIAL PRIMARY KEY,
  paper_id INTEGER NOT NULL,
  question TEXT NOT NULL,
  opt0 TEXT NOT NULL,
  opt1 TEXT NOT NULL,
  opt2 TEXT NOT NULL,
  opt3 TEXT NOT NULL,
  category TEXT DEFAULT ''
);

CREATE TABLE IF NOT EXISTS beexam_results (
  id SERIAL PRIMARY KEY,
  user_id INTEGER NOT NULL,
  paper_id INTEGER NOT NULL,
  score INTEGER DEFAULT 0,
  wrong INTEGER DEFAULT 0,
  skipped INTEGER DEFAULT 0,
  total INTEGER DEFAULT 0,
  pct DOUBLE PRECISION DEFAULT 0,
  grade TEXT DEFAULT 'F',
  time_taken INTEGER DEFAULT 0,
  played_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS bw_temp (
  user_id INTEGER PRIMARY KEY,
  questions_json TEXT NOT NULL,
  answers_json TEXT DEFAULT '[]',
  tabs INTEGER DEFAULT 0,
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS rb_temp (
  user_id INTEGER PRIMARY KEY,
  questions_json TEXT NOT NULL,
  log_json TEXT DEFAULT '[]',
  score INTEGER DEFAULT 0,
  tabs INTEGER DEFAULT 0,
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS cb_sessions (
  id SERIAL PRIMARY KEY,
  user_id INTEGER NOT NULL,
  questions TEXT NOT NULL,
  idx INTEGER DEFAULT 0,
  score INTEGER DEFAULT 0,
  log TEXT DEFAULT '[]',
  total INTEGER DEFAULT 0,
  end_time DOUBLE PRECISION DEFAULT 0,
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS jigsaw_levels (
  id SERIAL PRIMARY KEY,
  title TEXT NOT NULL,
  description TEXT DEFAULT '',
  image_path TEXT NOT NULL,
  grid_size INTEGER DEFAULT 4,
  order_num INTEGER DEFAULT 0,
  created TIMESTAMPTZ DEFAULT NOW()
);

CREATE TABLE IF NOT EXISTS jigsaw_progress (
  user_id INTEGER NOT NULL,
  level_id INTEGER NOT NULL,
  completed INTEGER DEFAULT 0,
  best_time INTEGER DEFAULT 0,
  stars INTEGER DEFAULT 0,
  completed_at TIMESTAMPTZ,
  PRIMARY KEY (user_id, level_id)
);


